{
  "mcpServers": {
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-obsidian"
      ],
      "env": {
        "OBSIDIAN_API_KEY": "${env:OBSIDIAN_API_KEY}"
      }
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "forge_extension": {
      "url": "http://localhost:14215/mcp"
    }
  }
}